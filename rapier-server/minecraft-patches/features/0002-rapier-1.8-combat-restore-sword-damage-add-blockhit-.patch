+    // rapier start - 1.8 combat: sword blocking component (50% damage reduction, no delay, no disable)
+    private static final BlocksAttacks SWORD_BLOCKING = new BlocksAttacks(
+        0.0F, 0.0F,
+        List.of(new BlocksAttacks.DamageReduction(90.0F, Optional.empty(), 0.0F, 0.5F)),
+        new BlocksAttacks.ItemDamageFunction(1000.0F, 0.0F, 0.0F),
+        Optional.empty(),
+        Optional.of(SoundEvents.SHIELD_BLOCK),
+        Optional.empty()
+    );
+    // rapier end
+    public static final Item WOODEN_SWORD = registerItem("wooden_sword", new Item.Properties().sword(ToolMaterial.WOOD, 4.0F, -2.4F).component(DataComponents.BLOCKS_ATTACKS, SWORD_BLOCKING)); // rapier - 1.8 damage + blockhit
