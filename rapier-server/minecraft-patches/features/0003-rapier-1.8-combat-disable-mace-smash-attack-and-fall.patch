@@ -166,7 +166,9 @@ public class MaceItem extends Item {
     }
 
     public static boolean canSmashAttack(LivingEntity entity) {
-        return entity.fallDistance > 1.5 && !entity.isFallFlying();
+        // rapier start - 1.8 combat: disable mace smash attack (no fall damage bonus, no aoe knockback)
+        return false;
+        // rapier end
