Subject: [PATCH] rapier - 1.8 combat: disable mace smash attack and fall
 damage bonus


diff --git a/net/minecraft/world/item/MaceItem.java b/net/minecraft/world/item/MaceItem.java
index c9e6cf2643333a49cda78bbe2956b0f8a9b8a996..d18118bcebad7976370aeeac675de4459f4bdb6f 100644
--- a/net/minecraft/world/item/MaceItem.java
