From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: diaaney <av6cts@gmail.com>
Date: Wed, 15 Apr 2026 09:31:50 -0700
Subject: [PATCH] rapier - 1.8 combat: partial-block markHurt, rod hit
 registers, unconditional KB y-kick

three bugs user hit during live PvP:

1. blockhit with sword: modern code skipped markHurt when anything was
   blocked, so a partial 50% sword block visually behaved like a shield
   full-block (no hurt flash, no kb, just sound). gated markHurt on
   partial-vs-full block via f1 < originAmount so shield still feels
   like shield but sword trades feel like 1.8.

2. fishing rod cast hitting a player did nothing server-side (only set
   hookedEntity). 1.8 called attackEntityFrom(source, 0.0F) on contact
   so the rod engaged hurt animation + invuln frame despite zero
   damage. restored via hurtOrSimulate(thrown(this, owner), 0.0F) in
   onHitEntity.

3. LivingEntity.knockback gated the upward y-kick on onGround, leaving
   deltaMovement.y untouched while airborne. 1.8 always applied
   motionY = min(0.4, motionY/2 + 0.4) regardless of ground state,
   which is why falling targets bounce up into combos instead of
   slamming into the floor. removed the onGround ternary.

diff --git a/net/minecraft/world/entity/LivingEntity.java b/net/minecraft/world/entity/LivingEntity.java
index d8342f20b03ddd39f003a0e291756dfb5ddbd182..f8c30459d9c10112bc64f9ea0735303cbfa27a99 100644
--- a/net/minecraft/world/entity/LivingEntity.java
+++ b/net/minecraft/world/entity/LivingEntity.java
@@ -1511,7 +1511,8 @@ public abstract class LivingEntity extends Entity implements Attackable, Waypoin
                     level.broadcastDamageEvent(this, damageSource);
                 }
 
-                if (!damageSource.is(DamageTypeTags.NO_IMPACT) && !flag) { // CraftBukkit - Prevent marking hurt if the damage is blocked
+                // rapier - 1.8 combat: partial-block (sword 50%) still needs markHurt so the hit animation, hurt flash, and knockback land. full block (shield factor=1.0) keeps modern "no impact" behavior.
+                if (!damageSource.is(DamageTypeTags.NO_IMPACT) && (!flag || f1 < originAmount)) {
                     this.markHurt();
                 }
 
@@ -2104,7 +2105,7 @@ public abstract class LivingEntity extends Entity implements Attackable, Waypoin
             // Paper start - knockback events
             Vec3 finalVelocity = new Vec3(
                 deltaMovement.x / 2.0 - vec3.x,
-                this.onGround() ? Math.min(0.4, deltaMovement.y / 2.0 + strength) : deltaMovement.y,
+                Math.min(0.4, deltaMovement.y / 2.0 + strength), // rapier - 1.8 combat: unconditional upward kick, 1.8 always did motionY = min(0.4, motionY/2 + 0.4) regardless of onGround. modern kept falling velocity on air-hit which pushes combo'd targets into the ground.
                 deltaMovement.z / 2.0 - vec3.z
             );
             Vec3 diff = finalVelocity.subtract(deltaMovement);
diff --git a/net/minecraft/world/entity/projectile/FishingHook.java b/net/minecraft/world/entity/projectile/FishingHook.java
index 761725e20509ff32e74ff7694dffb852a50db90e..e3b35e9ab895e7364910920d044bceb95e6c8179 100644
--- a/net/minecraft/world/entity/projectile/FishingHook.java
+++ b/net/minecraft/world/entity/projectile/FishingHook.java
@@ -296,6 +296,11 @@ public class FishingHook extends Projectile {
     protected void onHitEntity(EntityHitResult result) {
         super.onHitEntity(result);
         if (!this.level().isClientSide()) {
+            // rapier - 1.8 combat: rod contact registers as a hit (hurt animation + invuln frame) with 0 damage, same as 1.8 EntityFishHook.onImpact calling attackEntityFrom(source, 0.0F). lets rod-hit force target into invuln during combos without ever dealing HP damage.
+            Entity hit = result.getEntity();
+            if (this.getPlayerOwner() != null) {
+                hit.hurtOrSimulate(this.damageSources().thrown(this, this.getPlayerOwner()), 0.0F);
+            }
             this.setHookedEntity(result.getEntity());
         }
     }
